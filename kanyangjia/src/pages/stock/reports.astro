function getTypeLabel(type: string): string {
  return type === 'noon' ? '午间' : type === 'evening' ? '晚间' : type;
}

function getTypeBadge(type: string): { bg: string; color: string; text: string } {
  if (type === '午间') return { bg: '#fff3cd', color: '#856404', text: '☀️ 午间' };
  if (type === '晚间') return { bg: '#d1ecf1', color: '#0c5460', text: '🌙 晚间' };
  return { bg: '#e8e8e8', color: '#555', text: type };
}

function renderMarkdown(text: string): string {
  if (!text) return '';
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/^### (.*$)/gm, '<h4 style="margin:1rem 0 0.5rem;">$1</h4>')
    .replace(/^## (.*$)/gm, '<h3 style="margin:1.2rem 0 0.7rem;">$1</h3>')
    .replace(/^# (.*$)/gm, '<h2 style="margin:1.5rem 0 0.7rem;">$1</h2>')
    .replace(/\n/g, '<br>');
}
---

<Layout title={title} description={description}>
  <div style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
      <a href="/kanyangjia/stock.html" style="color: var(--color-muted); font-size: 0.9rem; text-decoration: none;">← 返回股票</a>
    </div>
    <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">📊 市场报告</h1>
    <p style="color: var(--color-muted);">每日/每周市场报告归档 · 共 {reports.length} 篇</p>
  </div>

  <!-- 类型筛选 -->
  <div style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
    {['全部', '午间', '晚间'].map(type => (
      <span style="padding: 0.4rem 1rem; border-radius: 20px; background: type === '全部' ? 'var(--color-accent)' : 'var(--color-card)', color: type === '全部' ? '#fff' : 'var(--color-text)', border: '1px solid var(--color-border)', cursor: 'pointer', fontSize: '0.9rem'}>{type}</span>
    ))}
  </div>

  <!-- 报告列表 -->
  <div style="display: flex; flex-direction: column; gap: 1rem;">
    {reports.map((report) => {
      const badge = getTypeBadge(report.report_type);
      return (
        <article style="background: var(--color-card); border-radius: 12px; border: 1px solid var(--color-border); padding: 1.5rem; cursor: pointer;"
          onclick={`document.getElementById('report-${report.id}').classList.toggle('hidden')`}>
          <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 0.75rem;">
            <span style="display: inline-block; padding: 0.2rem 0.6rem; border-radius: 8px; font-size: 0.8rem; background: {badge.bg}; color: {badge.color}; white-space: nowrap;">{badge.text}</span>
            <div style="flex: 1;">
              <h3 style="font-size: 1.1rem; margin: 0; line-height: 1.4;">{report.title}</h3>
              <span style="font-size: 0.8rem; color: var(--color-muted); margin-top: 0.3rem; display: block;">📅 {report.report_date}</span>
            </div>
          </div>
          <p style="color: #555; font-size: 0.9rem; line-height: 1.6; margin: 0;">{report.summary}</p>
          <details style="margin-top: 1rem; border-top: 1px solid var(--color-border); padding-top: 1rem;">
            <summary style="cursor: pointer; color: var(--color-accent); font-weight: 600; font-size: 0.9rem;">📖 展开完整内容</summary>
            <div style="margin-top: 1rem; line-height: 1.8; font-size: 0.9rem; color: #333;" set:html={renderMarkdown(report.content)}></div>
            {report.market_overview && (
              <div style="margin-top: 1rem; padding: 0.8rem; background: #f8f9fa; border-radius: 8px; font-size: 0.85rem; color: #666;">
                <strong>📈 市场概览：</strong> {report.market_overview}
              </div>
            )}
          </details>
        </article>
      );
    })}
  </div>

  <div style="margin-top: 1.5rem; padding: 1rem; background: #fff3cd; border-radius: 8px; border: 1px solid #ffc107; font-size: 0.85rem; color: #856404;">
    ⚠️ 本页面数据来源于群聊报告整理，仅供投资参考，不构成投资建议。
  </div>
</Layout>
